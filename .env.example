PORT=3000
LOG_LEVEL=debug
# Host port Docker binds MySQL to (docker-compose). Override if 3306 is taken;
# keep it in sync with DB_PORT below.
MYSQL_PORT=3306
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASS=app
DB_NAME=app
# RSA keypair (PEM). Generate with: deno task keys:gen
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=http://localhost:3000
# Optional bootstrap admin seeded by `deno task db:seed`
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-please
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
# SSO session lifetime (seconds); auth-code lifetime (seconds)
SSO_SESSION_TTL=2592000
AUTH_CODE_TTL=60
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Set true ONLY when behind a trusted reverse proxy (then X-Forwarded-For is honored)
TRUST_PROXY=false
# REDIS_URL=redis://localhost:6379
# REDIS_PORT=6379   # host port Docker binds Redis to (compose --profile redis)
